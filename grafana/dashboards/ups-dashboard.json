  "panels": [
    {
      "id": 1,
      "title": "Condition",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "description": "Overall UPS condition. Protected means utility power is online and no critical battery flag is active.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "Protected",
                  "color": "green",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "On Battery",
                  "color": "orange",
                  "index": 1
                }
              }
            },
            {
              "type": "value",
              "options": {
                "3": {
                  "text": "Check UPS",
                  "color": "red",
                  "index": 2
                }
              }
            }
          ],
          "noValue": "No data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calc": "lastNotNull",
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(network_ups_tools_ups_status{flag=~\"FSD|SD|OFF|OVER|RB|LB\", instance=~\"$instance\"} * 3 or network_ups_tools_ups_status{flag=~\"OB|DISCHRG|BYPASS|BOOST|TRIM|CAL\", instance=~\"$instance\"} * 2 or network_ups_tools_ups_status{flag=\"OL\", instance=~\"$instance\"} * 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "title": "Outages",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 3,
        "y": 0
      },
      "description": "Number of times the UPS transferred to battery (utility power went out) within the dashboard's selected time range. Counts each transition from online to on-battery.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calc": "lastNotNull",
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(sum_over_time((((network_ups_tools_ups_status{flag=\"OB\", instance=~\"$instance\"} == bool 1) - (network_ups_tools_ups_status{flag=\"OB\", instance=~\"$instance\"} offset 30s == bool 1)) > bool 0)[$__range:30s]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
