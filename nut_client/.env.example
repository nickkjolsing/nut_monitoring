PRIMARY_HOST=192.168.1.100          # the NUT server (upsd + UPS)
NUT_SECONDARY_PASSWORD=changeme     # match [upssecondary] in the primary's upsd.users
ONBATT_SHUTDOWN_DELAY=300           # seconds on battery before this host powers off (5 min)
DEBUG_LEVEL=1                       # upsmon verbosity in logs (0 off, 1 login/poll/state, 2+ noisy)