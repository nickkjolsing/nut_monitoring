PRIMARY_HOST=192.168.1.100          # the NUT server (upsd + UPS)
NUT_SECONDARY_PASSWORD=changeme     # match [upssecondary] in the primary's upsd.users
SHUTDOWN_START_CHARGE=100           # battery % at which the countdown starts (100 = as soon as on battery)
ONBATT_SHUTDOWN_DELAY=300           # countdown seconds, once started, before this host powers off (5 min)
DRY_RUN=false                       # true = log the shutdown instead of actually powering off (testing)
SHUTDOWN_GRACE=30                   # seconds to wait before the host actually powers off (0 = immediate)
DEBUG_LEVEL=0                       # upsmon verbosity in logs (0 off, 1 login/poll/state, 2+ noisy)