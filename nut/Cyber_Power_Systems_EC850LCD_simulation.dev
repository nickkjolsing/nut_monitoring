# ==== Simulation timeline (dummy-loop) ===================================
# Loops back to the baseline snapshot at the top of this file (~3.7 min cycle)

TIMER 60
# --- on battery, discharging ---
ups.status: OB DISCHRG
input.voltage: 0.0
output.voltage: 120.0

TIMER 30
battery.charge: 60
battery.runtime: 2400
battery.voltage: 13.2

TIMER 30
battery.charge: 30
battery.runtime: 900
battery.voltage: 12.4

TIMER 20
# --- Low-battery threshold crossed (battery.charge.low = 10) ---
ups.status: OB LB DISCHRG
battery.charge: 8
battery.runtime: 180
battery.voltage: 11.6

TIMER 20
# --- back online and recharging ---
ups.status: OL CHRG
input.voltage: 120.0
battery.charge: 12

TIMER 45